{
  "identifier": "main-capability",
  "description": "Main capability for PDF to PNG converter",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:write-all",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "**"
        }
      ]
    },
    "opener:allow-reveal-item-in-dir",
    "shell:default",
    "shell:allow-open"
  ]
}