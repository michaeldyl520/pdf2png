{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pdf2png",
  "version": "1.0.5",
  "identifier": "com.pdf2png.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Tauri PDF Converter",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "nsis"]
  },
  "plugins": {}
}